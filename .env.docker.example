APP_NAME=Chatbot
APP_ENV=production
APP_KEY=           # ← genera con: php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://TU_IP_VPS:3010

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Base de datos (apunta al servicio Docker "mysql") ─────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=chatbot
DB_USERNAME=root
DB_PASSWORD=CAMBIA_ESTE_PASSWORD

# ── Cache / Session / Queue ───────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=sync

# ── Redis (apunta al servicio Docker "redis") ─────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Broadcasting ──────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=reverb

# ── Reverb WebSocket ─────────────────────────────────────────────────────────
# REVERB_HOST aquí es para que PHP sepa dónde conectarse internamente
REVERB_APP_ID=chatbot
REVERB_APP_KEY=lmjexvaohw4amhwmsnlz
REVERB_APP_SECRET=CAMBIA_ESTE_SECRET
REVERB_HOST=reverb
REVERB_PORT=8081
REVERB_SCHEME=http

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token_real
TWILIO_WHATSAPP_FROM=whatsapp:+17854294558
